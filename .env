# Local organizer dashboard (standalone app in /organizer — default dev port 5174)
VITE_ORGANIZER_DASHBOARD_URL=http://localhost:5174

# Backend API (see API_REFERENCE.md). Final URL = `${VITE_API_BASE_URL}${VITE_API_PREFIX}`.
VITE_API_BASE_URL=https://myticket-api.kat-jr.com
VITE_API_PREFIX=/api/v1/main
# Set VITE_API_BASE_URL= (empty) in .env.local during dev to route requests through the Vite proxy at /api/v1/main.
