# Local organizer dashboard (standalone app in /organizer — default dev port 5174)
VITE_ORGANIZER_DASHBOARD_URL=https://myticket-organizer.kat-jr.com
VITE_TALENT_DASHBOARD_URL=https://myticket-talent.kat-jr.com
VITE_VENDOR_DASHBOARD_URL=https://myticket-organizer.kat-jr.com

# Backend API (see API_REFERENCE.md). Final URL = `${VITE_API_BASE_URL}${VITE_API_PREFIX}`.
VITE_API_BASE_URL=https://myticket-api.kat-jr.com
VITE_API_PREFIX=/api/v1/main
# Set VITE_API_BASE_URL= (empty) in .env.local during dev to route requests through the Vite proxy at /api/v1/main.

# Laravel Reverb (Pusher protocol) — see frontend-handoff-reverb-realtime-and-unified-chat.md
VITE_REVERB_APP_KEY=your-app-key
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
